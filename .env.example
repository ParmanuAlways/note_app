# ============================================================================
#  AI Notes & Scheduler — environment configuration
#  Copy to `.env` and adjust. NOTHING here points outside AFNET (NFR-3).
# ============================================================================

# --- Core ---
APP_ENV=development
APP_TIMEZONE=Asia/Kolkata          # single zone is acceptable in v1 (FR-21)
DATE_DISPLAY_FORMAT=DD MMM YYYY     # NFR-5 — never US MM/DD

# --- Database (Postgres + pgvector) ---
POSTGRES_USER=notes
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=notes
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Storage (originals, audio, markdown notes, git repos) ---
STORAGE_ROOT=/data/storage

# --- Auth (Keycloak) — auth only in v1 (FR-40) ---
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=notes
KEYCLOAK_CLIENT_ID=notes-frontend

# ============================================================================
#  INFERENCE LAYER (NFR-7) — swappable. No model name lives in code.
#  Switching model/hardware = edit these values + restart. No code change.
# ============================================================================

# --- Document extraction (vision-language model) ---
# engine: openai-vl (vLLM, GPU/prod) | ollama (CPU dev) | mock (no model)
INFERENCE_EXTRACTION_ENABLED=true
INFERENCE_EXTRACTION_ENGINE=openai-vl
INFERENCE_EXTRACTION_BASE_URL=http://vllm:8000/v1
INFERENCE_EXTRACTION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
INFERENCE_EXTRACTION_API_KEY=not-needed-local
# CPU dev alternative (Ollama): no code change, just these three —
#   INFERENCE_EXTRACTION_ENGINE=ollama
#   INFERENCE_EXTRACTION_BASE_URL=http://localhost:11434
#   INFERENCE_EXTRACTION_MODEL=qwen2.5vl:3b

# --- Voice transcription (WhisperLive streaming) ---
INFERENCE_TRANSCRIPTION_ENABLED=true
INFERENCE_TRANSCRIPTION_ENGINE=whisperlive
INFERENCE_TRANSCRIPTION_MODEL=large-v3-turbo
INFERENCE_TRANSCRIPTION_WS_URL=ws://whisperlive:9090
INFERENCE_TRANSCRIPTION_VAD=true

# --- Semantic search embeddings (OpenAI-compatible API) ---
INFERENCE_EMBEDDING_ENABLED=true
INFERENCE_EMBEDDING_BASE_URL=http://vllm-embed:8000/v1
INFERENCE_EMBEDDING_MODEL=BAAI/bge-m3
INFERENCE_EMBEDDING_DIM=1024
